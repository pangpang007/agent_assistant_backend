# ---- Application ----
APP_NAME=汤圆的代码助手
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string

# ---- NAS / Production (docker-compose.prod.yml) ----
POSTGRES_USER=tangyuan
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=tangyuan_db
API_PORT=8000
# Cloudflare Zero Trust → Networks → Tunnels → Docker 安装命令中的 Token
# 启动 Tunnel: docker compose -f docker-compose.prod.yml --profile tunnel up -d
# Tunnel Public Hostname Service URL 填: http://api:8000
CLOUDFLARE_TUNNEL_TOKEN=

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://tangyuan:tangyuan_dev@localhost:5432/tangyuan_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- CORS ----
# 生产环境改为前端域名，例如: ["https://app.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---- JWT ----
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Encryption ----
FERNET_KEY=change-me-fernet-key-32-bytes-base64

# ---- Transport encryption (前端敏感字段加密) ----
# 多 worker 时建议固定配置同一把 RSA 私钥 PEM（可用 \\n 表示换行）
TRANSPORT_RSA_PRIVATE_KEY_PEM=
# production 建议 true：强制 password/api_key 等使用 enc:v1:...
TRANSPORT_REQUIRE_ENCRYPTION=false


# ---- Phase 2: Tool Security ----
TOOL_TEST_TIMEOUT_SECONDS=30
TOOL_TEST_ALLOWED_DOMAINS=["api.openai.com","api.anthropic.com","generativelanguage.googleapis.com"]
TOOL_TEST_MAX_RESPONSE_SIZE=1048576

# ---- Phase 1: Password ----
BCRYPT_ROUNDS=12

# ---- Phase 1: Team ----
TEAM_MAX_MEMBERS=50
INVITE_CODE_LENGTH=6

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Phase 3: Knowledge Base ----
UPLOAD_BASE_DIR=./uploads
DEFAULT_EMBEDDING_API_KEY=
DEFAULT_EMBEDDING_BASE_URL=https://api.openai.com/v1
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=20
EMBEDDING_REQUEST_TIMEOUT=60

# ---- Phase 5: Workflow Execution ----
EXECUTION_MAX_CONCURRENT=10
EXECUTION_DEFAULT_TIMEOUT=300
REVIEW_DEFAULT_TIMEOUT=3600
